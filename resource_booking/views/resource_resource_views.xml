<odoo>
    <record id="view_resource_item_tree" model="ir.ui.view">
        <field name="name">resource.item.tree</field>
        <field name="model">resource.item</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="category"/>
                <field name="manager_id"/>
                <field name="approval_policy"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_resource_item_form" model="ir.ui.view">
        <field name="name">resource.item.form</field>
        <field name="model">resource.item</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="category"/>
                        </group>
                        <group>
                            <field name="manager_id"/>
                            <field name="approval_policy"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <field name="description"/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_resource_item" model="ir.actions.act_window">
        <field name="name">Ressources</field>
        <field name="res_model">resource.item</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_resource_booking_item" name="Ressources" parent="menu_resource_booking_root" action="action_resource_item" sequence="20"/>
</odoo>
