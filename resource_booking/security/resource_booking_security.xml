<odoo>
    <record id="group_resource_booking_user" model="res.groups">
        <field name="name">Resource Booking User</field>
        <field name="category_id" ref="base.module_category_operations"/>
    </record>

    <record id="group_resource_booking_manager" model="res.groups">
        <field name="name">Resource Booking Manager</field>
        <field name="category_id" ref="base.module_category_operations"/>
        <field name="implied_ids" eval="[(4, ref('resource_booking.group_resource_booking_user'))]"/>
    </record>

    <record id="resource_booking_rule_own_or_approver" model="ir.rule">
        <field name="name">Réservations personnelles ou à approuver</field>
        <field name="model_id" ref="model_resource_booking"/>
        <field name="groups" eval="[(4, ref('resource_booking.group_resource_booking_user'))]"/>
        <field name="domain_force">['|', ('requester_id', '=', user.id), ('approval_actor_id', '=', user.id)]</field>
    </record>

    <record id="resource_booking_rule_manager_all" model="ir.rule">
        <field name="name">Resource Booking manager all access</field>
        <field name="model_id" ref="model_resource_booking"/>
        <field name="groups" eval="[(4, ref('resource_booking.group_resource_booking_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>
</odoo>
